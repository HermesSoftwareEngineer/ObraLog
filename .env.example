# ── LLM ─────────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=

# ── Banco de dados ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/diario_obra
REDIS_URL=redis://localhost:6379

# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_APP=backend.main
OBRALOG_ENV=dev                         # dev | prod

# ── Canal do bot ─────────────────────────────────────────────────────────────
# Seleciona qual canal de mensagens está ativo. Apenas um por vez.
BOT_CHANNEL=telegram                    # telegram | whatsapp

# ── Telegram ─────────────────────────────────────────────────────────────────
# Obrigatório apenas quando BOT_CHANNEL=telegram
TELEGRAM_TOKEN=
TELEGRAM_POLLING_IN_DEV=true           # true = polling em dev, false = webhook
TELEGRAM_WEBHOOK_SECRET_TOKEN=         # string aleatória para validar o webhook (opcional)

# ── WhatsApp Business Cloud API ──────────────────────────────────────────────
# Obrigatório apenas quando BOT_CHANNEL=whatsapp
# Todos os valores obtidos em developers.facebook.com → seu App → WhatsApp

WHATSAPP_ACCESS_TOKEN=                 # System User token (prod) ou token temporário (dev)
WHATSAPP_PHONE_NUMBER_ID=              # Phone Number ID — aba "API Setup" no Meta Developers
WHATSAPP_VERIFY_TOKEN=                 # Qualquer string que você escolher; usada na verificação do webhook
WHATSAPP_APP_SECRET=                   # App Secret — Settings → Basic no Meta Developers

# ── URL pública ───────────────────────────────────────────────────────────────
# Necessária em prod (domínio real) ou em dev com ngrok para webhooks do WhatsApp.
# Em dev com Telegram + polling, pode deixar vazio.
PUBLIC_BASE_URL=                       # ex: https://meuapp.com ou https://xxxx.ngrok-free.app

# ── Supabase Storage ──────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ── Observabilidade ──────────────────────────────────────────────────────────
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Auth ─────────────────────────────────────────────────────────────────────
AUTH_SECRET_KEY=
